# Frontend Environment Variables
# Copy this file to .env and update values as needed

# Backend API URL (used by axios for REST API calls)
# Vite uses VITE_* prefix for environment variables
VITE_API_URL=http://localhost:8000

# WebSocket URL (used for real-time updates)
VITE_WS_URL=ws://localhost:8000/ws

# Docker deployment uses REACT_APP_* prefix (passed at runtime)
# Note: These are used in docker-compose.yml but need to be mapped to VITE_* at build time
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000/ws

# Map Style URL (optional - defaults to MapLibre demo tiles)
# MapLibre GL JS is open-source and does not require an access token.
# You can use free tile providers like:
#   - MapLibre demo: https://demotiles.maplibre.org/style.json
#   - MapTiler (free tier): https://api.maptiler.com/maps/streets/style.json?key=YOUR_KEY
#   - Stadia Maps: https://tiles.stadiamaps.com/styles/alidade_smooth.json
# VITE_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
